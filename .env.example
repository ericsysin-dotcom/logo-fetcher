# Optional: Brandfetch API key for richer company descriptions
# VITE_BRANDFETCH_API_KEY=your_key_here

# Optional: remove.bg API key as fallback for background removal
# VITE_REMOVE_BG_API_KEY=your_key_here

# Default Groq token used by the AI auto-arrange feature.
# Get a free token at https://console.groq.com/keys
# WARNING: this token will be visible in the built JS bundle — use a free-tier
# token. Worst case: rate limit is hit.
VITE_GROQ_TOKEN=gsk_your_token_here
